@page "/stageview"
@* Attention : J'ai mis les rôles en MAJUSCULES pour correspondre à ta base de données ! *@
@attribute [Authorize(Roles = "ETUDIANT,ENTREPRISE")]

<h1 class="mb-4">Tableau des offres de stage</h1>

@if (Stages == null)
{
   <LoadingSpinner Message="Récupération des offres de stage..." />
}
else if (!Stages.Any())
{
    <div class="alert alert-info shadow-sm text-center mt-4" role="alert">
        <h4 class="alert-heading">Aucun stage trouvé</h4>
        <p>Il n'y a actuellement aucune offre de stage disponible dans le système.</p>
    </div>
}
else
{
    <div class="table-responsive shadow-sm">
        <table class="table table-hover table-striped border">
            <thead class="table-dark">
                <tr>
                    <th>Titre</th>
                    <th>Description</th>
                    <th>Statut</th>
                    <th>Création</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stage in Stages)
                {
                    <tr>
                        <td>
                            <AuthorizeView Roles="ENTREPRISE">
                                <Authorized>
                                    <a class="text-primary fw-bold" style="text-decoration: none;" href="@($"stageedit/{stage.StageId}")">
                                        @stage.Titre <span class="oi oi-pencil ms-1" style="font-size: 0.8em;"></span>
                                    </a>
                                </Authorized>
                                <NotAuthorized>
                                    <span class="fw-bold">@stage.Titre</span>
                                </NotAuthorized>
                            </AuthorizeView>
                        </td>
                        <td>@stage.Description</td>
                        <td>
                            <span class="badge bg-secondary">@stage.StageStatut?.DescriptionStatut</span>
                        </td>
                        <td>@stage.DateCreation.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}